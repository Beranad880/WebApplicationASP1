@page "{id}"
@model WebApplicationASP1.Pages.Products.EditModel
@{
    ViewData["Title"] = "Upravit produkt";
}

<a asp-page="Index" class="back-link">Zpět na seznam</a>

<div class="page-header">
    <h1>Upravit položku</h1>
    <p>@Model.Product.Name</p>
</div>

<div class="centered-container">
    <div class="form-card">
        <form method="post">
            <input type="hidden" asp-for="Product.Id" />
            <div class="form-group">
                <label asp-for="Product.Name">Název</label>
                <input asp-for="Product.Name" required />
            </div>
            <div class="form-group">
                <label asp-for="Product.Price">Cena (Kč)</label>
                <input asp-for="Product.Price" type="number" step="0.01" required />
            </div>
            <div class="form-group">
                <label asp-for="Product.Category">Kategorie</label>
                <div style="display: flex; gap: 0.5rem;">
                    <select asp-for="Product.Category" asp-items="Model.Categories" required>
                        <option value="">-- Vyberte kategorii --</option>
                    </select>
                    <a asp-page="/Categories/Create" class="btn-primary" title="Přidat novou kategorii">+</a>
                </div>
            </div>
            <div class="form-group">
                <label asp-for="Product.Stock">Skladem (ks)</label>
                <input asp-for="Product.Stock" type="number" required />
            </div>
            <div class="form-group">
                <label asp-for="Product.Description">Popis</label>
                <textarea asp-for="Product.Description" rows="4"></textarea>
            </div>

            <div style="display: flex; gap: 0.75rem; margin-top: 0.5rem;">
                <button type="submit" class="btn-primary" style="flex: 1;">Uložit změny</button>
                <a asp-page="Index" class="btn-danger" style="flex: 1; text-align: center;">Zrušit</a>
            </div>
        </form>
    </div>
</div>
