@page
@model WebApplicationASP1.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Seznam produktů";
}

<div class="title-row">
    <h1>Položky</h1>
    <a asp-page="Create" class="btn-primary">Přidat položku</a>
</div>

<form method="get" class="search-container">
    <input type="text" name="SearchString" value="@Model.SearchString" placeholder="Hledat podle názvu nebo popisu..." class="search-input" />
    <button type="submit" class="btn-primary">Hledat</button>
    @if (!string.IsNullOrEmpty(Model.SearchString))
    {
        <a asp-page="./Index" class="btn-danger">Zrušit</a>
    }
</form>

<div class="table-container">
    <table class="products-table">
        <thead>
            <tr>
                <th>Název</th>
                <th>Kategorie</th>
                <th>Cena</th>
                <th>Skladem</th>
                <th>Akce</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Products)
            {
                <tr>
                    <td>
                        <div class="product-name">@item.Name</div>
                        <div class="product-description-short">@item.Description</div>
                    </td>
                    <td><span class="category-badge">@item.Category</span></td>
                    <td class="price-cell">@item.Price.ToString("N2") Kč</td>
                    <td>
                        <span class="stock-indicator @(item.Stock <= 0 ? "out" : "")">
                            @item.Stock ks
                        </span>
                    </td>
                    <td>
                        <div class="table-actions">
                            <a asp-page="./Edit" asp-route-id="@item.Id" class="btn-icon" title="Upravit">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                            </a>
                            <a asp-page="./Delete" asp-route-id="@item.Id" class="btn-icon btn-icon-danger" title="Smazat">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                            </a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Products.Any())
{
    <div class="empty-state">
        <p>Nebyly nalezeny žádné položky.</p>
        @if (!string.IsNullOrEmpty(Model.SearchString))
        {
            <a asp-page="./Index" class="btn-primary">Zobrazit vše</a>
        }
        else
        {
            <a asp-page="Create" class="btn-primary">Přidat první položku</a>
        }
    </div>
}
