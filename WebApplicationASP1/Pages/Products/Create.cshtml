@page
@model WebApplicationASP1.Pages.Products.CreateModel
@{
    ViewData["Title"] = "Nový produkt";
}

<div class="title-row">
    <h1>Vytvořit nový produkt</h1>
    <a asp-page="Index">Zpět na seznam</a>
</div>

<div class="centered-container">
    <div class="card">
        <form method="post">
            <div class="form-group">
                <label asp-for="Product.Name">Název</label>
                <input asp-for="Product.Name" required />
            </div>
            <div class="form-group">
                <label asp-for="Product.Price">Cena</label>
                <input asp-for="Product.Price" type="number" step="0.01" required />
            </div>
            <div class="form-group">
                <label asp-for="Product.Category">Kategorie</label>
                <input asp-for="Product.Category" required />
            </div>
            <div class="form-group">
                <label asp-for="Product.Stock">Skladem (ks)</label>
                <input asp-for="Product.Stock" type="number" required />
            </div>
            <div class="form-group">
                <label asp-for="Product.Description">Popis</label>
                <textarea asp-for="Product.Description" rows="4"></textarea>
            </div>
            
            <div style="display: flex; gap: 1rem; margin-top: 1rem;">
                <button type="submit" class="btn-primary" style="flex: 1;">Uložit produkt</button>
                <a asp-page="Index" class="btn-danger" style="flex: 1; text-align: center;">Zrušit</a>
            </div>
        </form>
    </div>
</div>
