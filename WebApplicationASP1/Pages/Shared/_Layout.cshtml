<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sklad</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    @{
        var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    }
    <header>
        <nav class="container">
            <a class="logo" asp-page="/Products/Index">ProductManager</a>
            <ul>
                <li><a asp-page="/Products/Index" class="@(currentPage.StartsWith("/Products") ? "active" : "")">Položky</a></li>
                <li><a asp-page="/Categories/Index" class="@(currentPage.StartsWith("/Categories") ? "active" : "")">Kategorie</a></li>
            </ul>
        </nav>
    </header>

    <main class="container">
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            &copy; 2026 - Sklad položek
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
